# Stage 1: build
FROM golang:1.24-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /migrate ./cmd/migrate

# Stage 2: runtime
# migrations/ dir must be present at WORKDIR because cmd/migrate uses "file://migrations"
FROM alpine:latest
WORKDIR /app
COPY --from=builder /migrate .
COPY migrations/ ./migrations/
ENTRYPOINT ["/app/migrate", "up"]
