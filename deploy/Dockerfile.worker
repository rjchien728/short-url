# Stage 1: build
FROM golang:1.24-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /worker ./cmd/worker

# Stage 2: runtime
# ca-certificates is required for outbound HTTPS requests (OG metadata fetching)
FROM alpine:latest
RUN apk --no-cache add ca-certificates && \
    adduser -D -g '' appuser
WORKDIR /app
COPY --from=builder /worker .
USER appuser
ENTRYPOINT ["/app/worker"]
